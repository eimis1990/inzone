# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit it.
#
# Source it before running `npm run release`:
#   set -a; source .env; set +a; npm run release
#
# Or use a tool like `dotenv-cli`:
#   npx dotenv -e .env -- npm run release

# ── Apple notarization (electron-builder reads these directly) ────

# Your Apple ID — the email you use to sign in to developer.apple.com.
APPLE_ID="you@example.com"

# App-specific password generated at:
#   appleid.apple.com → Sign-In and Security → App-Specific Passwords
# Format is four hyphen-separated groups: "abcd-efgh-ijkl-mnop".
# This is NOT your Apple ID password — it's a one-purpose token.
APPLE_APP_SPECIFIC_PASSWORD="abcd-efgh-ijkl-mnop"

# 10-character team ID. Find it at:
#   developer.apple.com → Account → Membership Details
# Looks like "ABCD123456".
APPLE_TEAM_ID="ABCD123456"

# ── Code signing certificate ──────────────────────────────────────

# Path to the .p12 export of your Developer ID Application cert.
# Export it from Keychain Access (right-click the cert → Export →
# choose Personal Information Exchange .p12, set a password).
# Absolute path is safest; relative paths are resolved from cwd.
CSC_LINK="/absolute/path/to/Developer-ID-Application.p12"

# Password you set when exporting the .p12 above.
CSC_KEY_PASSWORD="your-p12-password"

# ── GitHub Releases publish (electron-builder reads GH_TOKEN) ────

# Personal access token with `repo` scope (classic) or
# "Contents: read+write" (fine-grained). Used by electron-builder
# to upload the DMG/zip/yml to your GitHub Release.
# Create at: github.com/settings/tokens
GH_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
